# searchbox config. Only LLAMA_URL needs to point at a running OpenAI-compatible model
# server (e.g. llama-server). Everything else has working defaults; uncomment to override.

# --- base model (BASE-MODEL ABLATION knob) -----------------------------------
# Point Pi at any OpenAI-compatible /v1 endpoint. Swap this (+ MODEL_ID, CONTEXT_WINDOW) to
# ablate the base LLM. Default assumes a local llama-server on :8080.
LLAMA_URL=http://127.0.0.1:8080
# MODEL_ID=qwen3.6                 # agent-facing model id (free label; must match models.json)
# CONTEXT_WINDOW=131072            # context window for the chosen model
# MAX_OUTPUT_TOKENS=8192
# THINKING_LEVEL=high              # high|medium|off
# LLAMA_API_KEY=sk-local

# --- retrieval backend (BACKEND ABLATION knob): local weights vs Jina cloud API ----
# Invisible to the agent - same tools either way; only this decides where embed/rerank runs.
# EMBED_BACKEND=local              # local | api
# RERANK_BACKEND=local             # local | api
# JINA_API_KEY=jina_...            # required when *_BACKEND=api
# API_EMBED_MODEL=jina-embeddings-v5-text-small
# API_RERANK_MODEL=jina-reranker-v3
# JINA_API_BASE=https://api.jina.ai/v1

# --- retrieval models, LOCAL backend (RETRIEVAL ABLATION knob) ----------------
# EMBED_MODEL=jinaai/jina-embeddings-v5-text-small
# RERANK_MODEL=jinaai/jina-reranker-v3
# EMBED_DEVICE=cpu                 # cpu keeps VRAM for the LLM; cuda if you have headroom
# CHUNK_SIZE=1400
# CHUNK_OVERLAP=180

# --- which corpus tools the agent gets (TOOL ABLATION knob) -------------------
# Comma list of enabled tools; empty = none (bash/read only); unset = all.
# SEARCHBOX_TOOLS=semantic_search,passage_rerank

# --- turn budget (BUDGET ABLATION knob) --------------------------------------
# The run keeps going for this many turns (agent cycles) before the answer is finalized.
# Token cost is recorded per turn but is not the stop condition.
# TURN_BUDGET=10
# BUDGET_METRIC=input          # which token field the per-turn accounting reports

# --- hard safety ceilings (backstops; the run normally stops on the turn budget) ---
# MAX_SECONDS=21600
# TURN_TIMEOUT=1200            # per-turn wall-clock abort
# DATAROOM_BOOT_TIMEOUT=600    # wait for the sidecar to come up

# --- single-slot scheduler (one llama slot; jobs run serially) ----------------
# Foreground jobs (fresh submits + explicit resumes) run FIFO. When the slot is otherwise idle,
# AUTO_BACKFILL resumes the oldest paused job (--continue) to keep the slot busy; a backfill run is
# preemptible. A user pause is sticky ('held') and is never auto-resumed.
# AUTO_BACKFILL=1       # 0 = leave the slot idle instead of backfilling paused jobs
# PREEMPT_FOREGROUND=1  # 1 = a fresh submit/resume preempts ANY running job (incl. another
#                       #     foreground job) and takes the slot now; 0 = it waits its turn
